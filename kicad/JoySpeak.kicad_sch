			)
			(justify left top)
		)
		(uuid "295d7a2e-4720-4a9d-8b25-400333dd95de")
	)
	(text_box "Decouple all power inputs! Separate A and D!\n\nConnect the EP directly to your AVSS (Analog Ground) plane on your PCB, and make sure it is heavily stitched to your ground copper layers using multiple thermal vias."
		(exclude_from_sim no)
		(at 17.78 69.6486 0)
		(size 63.5 14.1714)
		(margins 0.9525 0.9525 0.9525 0.9525)
