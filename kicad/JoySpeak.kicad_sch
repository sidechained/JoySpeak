		(uuid "35bbca56-65db-4b90-9080-a04205d7177c")
	)
	(text_box "RP2040 to Codec (Playback):\n- RP2040 I2S Out -> DIN Pin -> Codec DAC -> Speakers/Headphones\n\nCodec to RP2040 (Recording):\n- Microphone/Line-In -> Codec ADC -> DOUT Pin -> RP2040 I2S In"
		(exclude_from_sim no)
		(at 71.12 149.86 0)
		(size 86.36 12.7)
